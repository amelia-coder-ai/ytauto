# ---- Primary AI provider: vercel-ai-gateway | openrouter | deepseek | ollama ----
PRIMARY_AI_PROVIDER=ollama

# ---- Vercel AI Gateway (when PRIMARY_AI_PROVIDER=vercel-ai-gateway) ----
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-4o-mini

# ---- OpenRouter (when PRIMARY_AI_PROVIDER=openrouter) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# ---- DeepSeek (when PRIMARY_AI_PROVIDER=deepseek) ----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- Ollama (local — no API key needed) ----
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ---- YouTube Data API v3 ----
YOUTUBE_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

MODAL_ENDPOINT_URL=https://your-username--explainer-videos-flask-app.modal.run
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_APP_URL=http://localhost:3000
PROGRESS_SECRET=change-me-to-a-random-string
