# ---- AI provider keys ----
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- OpenRouter (viral topics + script generation) ----
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-oss-20b:free

# ---- Ollama (local development — no API key needed) ----
